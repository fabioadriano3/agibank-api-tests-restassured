{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error Response",
  "type": "object",
  "required": ["status", "message", "code"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["error"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "code": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}

