{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Random Image Response",
  "type": "object",
  "required": ["message"],
  "properties": {
    "status": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "pattern": "^https?://.+"
    }
  },
  "additionalProperties": true
}

